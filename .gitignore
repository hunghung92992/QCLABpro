# ==========================================
# 10. FILE ZIP / GÓI NÉN TẠM
# ==========================================
*.zip
*.7z
*.rar

# ==========================================
# 11. NHẬT KÝ / DỮ LIỆU RUNTIME KHÁC
# ==========================================
*.pid
*.seed
*.out
*.err

# ==========================================
# 12. CHẶN THƯ MỤC BUILD RIÊNG NẾU CÓ
# ==========================================
release/
artifacts/

